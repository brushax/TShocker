{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tshocker",
  "version": "0.1.0",
  "identifier": "com.brushax.tshocker",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "TShocker",
        "width": 960,
        "height": 780,
        "minWidth": 960,
        "minHeight": 780,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "macOS": {
      "signingIdentity": "-",
      "entitlements": null
    }
  }
}
